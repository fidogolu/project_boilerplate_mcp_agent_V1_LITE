# =========================================================================
# 📊 LOGGING & DEBUG
# =========================================================================
LOG_LEVEL=DEBUG

# ===========================================
# 🤖 LLM ENDPOINT
# ===========================================
WORKER_LLM_URL=http://localhost:10001/v1
WORKER_MODEL_NAME=your-llm-model-name

# ===========================================
# 🔗 MCP ENDPOINT — Base URL
# ===========================================
MCP_BASE_URL=https://mcp.example.com

# ===========================================
# 🔒 SECURITY MODE — lite | full | remote | llamafirewall
# ===========================================
SECURITY_MODE=llamafirewall
LLAMAFIREWALL_TIMEOUT=30
LLAMAFIREWALL_THRESHOLD=0.5
LLAMAFIREWALL_INPUT_THRESHOLD=0.6
LLAMAFIREWALL_OUTPUT_THRESHOLD=0.6
SECURITY_SERVICE_URL=

# Security bypass — comma-separated categories to skip (empty = block all)
# Available: PromptInjection, Toxicity, Sensitive, SelfHarm, Sexual, Violence, Illegal, Harassment
SECURITY_BYPASS_CATEGORIES=

# ===========================================
# 📊 Langfuse observability
# ===========================================
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3000

# ===========================================
# 📊 HuggingFace mode
# ===========================================
HF_HUB_OFFLINE=true
TRANSFORMERS_OFFLINE=true
HF_HUB_DISABLE_TELEMETRY=true
TRANSFORMERS_NO_ADVISORY_WARNINGS=true

# Local cache directory for HuggingFace models
HF_HOME=./hf_cache

# ===========================================
# 📊 Gradio
# ===========================================
GRADIO_ANALYTICS_ENABLED=false
GRADIO_TEMP_DIR=./temp_data
MAX_MESSAGE_LENGTH=4096
MAX_CONVERSATION_HISTORY=50
